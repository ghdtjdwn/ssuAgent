# Upstream MCP server
SSUMCP_URL=https://ssumcp.duckdns.org/mcp

# LangGraph PostgreSQL checkpointer
DATABASE_URL=postgresql://ssuai:dev@localhost:5432/ssuai
AGENT_PG_POOL_MAX_SIZE=5

# Configure at least one provider. Never commit real values.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
GROQ_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENROUTER_API_KEY=

# Local HTTP boundary. Production requires a non-empty shared key.
AGENT_API_KEY=
AGENT_API_KEY_REQUIRED=false
ALLOWED_ORIGINS=http://localhost:3000
AGENT_RATE_LIMIT=30/minute
AGENT_MAX_MESSAGE_CHARS=8000
